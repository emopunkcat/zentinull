# ════════════════════════════════════════════════════════════════════════════════
# NETWORK ACCESS: You have two options for reaching the 6 IT sources.
#
# Option A — Direct access (this machine is on the IT network):
#   Fill in the real IPs/creds below and run normally:
#     python3 serve.py pipeline
#
# Option B — SSH tunnel (this machine is remote, use a jump box):
#   Leave the vars below at their defaults (empty/placeholder).
#   Run via the tunnel helper — it exports localhost:PORT overrides:
#     ./scripts/tunnel.sh user@jump-box serve.py pipeline
#
#   Tunnel port mapping (set by tunnel.sh, overrides whatever is below):
#     SHAREPOINT_BASE_URL=http://localhost:15678/webhook
#     FG_HOST=localhost FG_PORT=14443
#     ME_CLOUD_BASE_URL=https://localhost:18080/api/1.4
#     ME_MDM_BASE_URL=https://localhost:18081/api/v1/mdm
#     SDP_BASE_URL=https://localhost:18082
#     AD_SERVER=ldap://localhost:1389
#     ZBX_URL=https://localhost:18083/api_jsonrpc.php
#
# ════════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════════
# IMPORTANT: Use ZENTINULL_HOST and ZENTINULL_PORT (not API_HOST / API_PORT).
# These are defined at the bottom of this file (lines 36-39) and are the only
# server address/port env vars this project reads for the FastAPI server.
# API_HOST=0.0.0.0 and API_PORT=8001 are NOT checked by the application.
# ════════════════════════════════════════════════════════════════════════════════

# ── Authentication ──────────────────────────────────────────
AD_PASSWORD=
AD_USER=
AD_SERVER=ldap://dc.example.com:389
AD_SEARCH_BASE=DC=moonlite,DC=local

FG_HOST=
FG_PORT=8443
FG_API_KEY=

# Primary SharePoint webhook URL
N8N_BASE_URL=
# Fallback SharePoint URL (used when N8N_BASE_URL is not set)
SHAREPOINT_BASE_URL=

ME_CLIENT_ID=
ME_CLIENT_SECRET=
ME_OAUTH_FILE=data/me_oauth.json
# ManageEngine Endpoint Central API base URL
ME_CLOUD_BASE_URL=https://endpointcentral.manageengine.com/api/1.4
# ManageEngine MDM API base URL
ME_MDM_BASE_URL=https://mdm.manageengine.com/api/v1/mdm

SDP_BASE_URL=https://sdpondemand.manageengine.com
SDP_CLIENT_ID=
SDP_CLIENT_SECRET=
SDP_OAUTH_FILE=data/sdp_oauth.json

ZBX_URL=https://zabbix.example.com/api_jsonrpc.php
ZBX_TOKEN=

# ── Splink ──────────────────────────────────────────────────
SPLINK_THRESHOLD=-5

# ── Server (optional overrides) ─────────────────────────────
# ZENTINULL_HOST=0.0.0.0
# ZENTINULL_PORT=8001
# ZENTINULL_LOG_LEVEL=INFO
# ZENTINULL_LOG_JSON=false
