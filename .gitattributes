# Auto-detect text files and normalize line endings
* text=auto

# Python source
*.py text diff=python

# Markdown
*.md text

# YAML
*.yml text
*.yaml text

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text
docker-compose.yml text

# Dotenv
.env.example text

# Generated data — binary
data/*.sqlite binary
data/*.duckdb binary
